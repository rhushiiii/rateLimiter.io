{
  "name": "distributed-rate-limiter",
  "version": "1.0.0",
  "description": "Distributed API rate-limiting service using Redis token-bucket algorithm",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "load-test": "node scripts/loadTest.js",
    "benchmark": "node scripts/loadTest.js --rps 1000 --duration 30 --concurrency 80 --ips 20",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
